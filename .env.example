# petwalker - copy to .env and fill in. .env is gitignored.
# Defaults below = dev mode with MinIO + cognito-local. ZERO real AWS keys needed.

# ----- runtime mode --------------------------------------------------------
NODE_ENV=development
APP_ENV=dev          # dev | prod  (prod requires real AWS creds and refuses dev endpoints)

# ----- Postgres ------------------------------------------------------------
POSTGRES_USER=petwalker
POSTGRES_PASSWORD=changeme_postgres
POSTGRES_DB=petwalker
POSTGRES_PORT=5432
DATABASE_URL="postgres://petwalker:changeme_postgres@localhost:5432/petwalker"

# ----- Redis ---------------------------------------------------------------
REDIS_PASSWORD=changeme_redis
REDIS_PORT=6379
REDIS_URL="redis://default:changeme_redis@localhost:6379"

# ----- pgAdmin -------------------------------------------------------------
PGADMIN_EMAIL="[email protected]"
PGADMIN_PASSWORD=changeme_pgadmin
PGADMIN_PORT=5050

# ----- API -----------------------------------------------------------------
API_PORT=3001
PUBLIC_API_URL=http://localhost:3001

# ----- AWS (dev: empty / minio creds; prod: real IAM Role or keys) ----------
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin

# ----- S3 / MinIO ----------------------------------------------------------
# DEV: AWS_S3_ENDPOINT points at MinIO running in docker-compose.
# PROD: leave AWS_S3_ENDPOINT empty (SDK uses real AWS).
AWS_S3_REGION=us-east-1
AWS_S3_BUCKET_PETS=petwalker-pets-dev
AWS_S3_ENDPOINT=http://localhost:9000
AWS_S3_FORCE_PATH_STYLE=true
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

# ----- Cognito / cognito-local ---------------------------------------------
# DEV: COGNITO_ENDPOINT points at cognito-local. IDs match the preloaded pool
# in infra/cognito-local/.cognito/db/local_petwalker.json.
# PROD: leave COGNITO_ENDPOINT empty, set real pool/client IDs.
COGNITO_USER_POOL_ID=local_petwalker
COGNITO_CLIENT_ID=petwalker_local_client
COGNITO_CLIENT_SECRET=
COGNITO_DOMAIN=
COGNITO_ENDPOINT=http://localhost:9229
COGNITO_LOCAL_PORT=9229

# ----- Stripe (M4) ---------------------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CONNECT_CLIENT_ID=
STRIPE_PUBLISHABLE_KEY=

# ----- Expo Push (M5) ------------------------------------------------------
EXPO_ACCESS_TOKEN=

# ----- Web (Next.js) -------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_AWS_REGION=us-east-1
NEXT_PUBLIC_COGNITO_USER_POOL_ID=local_petwalker
NEXT_PUBLIC_COGNITO_CLIENT_ID=petwalker_local_client
NEXT_PUBLIC_COGNITO_ENDPOINT=http://localhost:9229
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# ----- Mobile (Expo) -------------------------------------------------------
EXPO_PUBLIC_API_URL=http://localhost:3001
EXPO_PUBLIC_AWS_REGION=us-east-1
EXPO_PUBLIC_COGNITO_USER_POOL_ID=local_petwalker
EXPO_PUBLIC_COGNITO_CLIENT_ID=petwalker_local_client
EXPO_PUBLIC_COGNITO_ENDPOINT=http://localhost:9229
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=
