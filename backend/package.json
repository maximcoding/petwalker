{
  "name": "@petwalker/backend",
  "version": "0.0.0",
  "private": true,
  "description": "petwalker API — NestJS on Fastify, Cognito auth, Drizzle/Postgres",
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/main.ts",
    "start": "node dist/main.js",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist .turbo drizzle/meta",
    "db:generate": "NODE_OPTIONS='--require tsx/cjs' drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:seed": "tsx src/db/seed.ts",
    "db:bulk-seed": "tsx src/db/bulk-seed.ts",
    "db:studio": "NODE_OPTIONS='--require tsx/cjs' drizzle-kit studio"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.658.0",
    "@aws-sdk/s3-request-presigner": "^3.658.0",
    "@fastify/websocket": "^10.0.1",
    "@nestjs/bullmq": "^10.2.3",
    "@nestjs/common": "^10.4.0",
    "@nestjs/core": "^10.4.0",
    "@nestjs/platform-fastify": "^10.4.0",
    "@petwalker/shared": "workspace:*",
    "aws-jwt-verify": "^4.0.1",
    "bullmq": "^5.13.0",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.36.0",
    "expo-server-sdk": "^3.10.0",
    "fastify": "^4.28.0",
    "postgres": "^3.4.4",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "stripe": "^17.3.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/ws": "^8.5.13",
    "drizzle-kit": "^0.27.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.4",
    "vitest": "^2.1.0"
  }
}
